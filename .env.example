# ==========================================
# GMAIL TRIAGE AGENT - SECRETS FILE
# Copy this file to '.env' and fill in the values below.
# NEVER share your .env file or upload it to GitHub!
# ==========================================

# 1. Google Gemini API Key
# Get this for free from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# 2. Gmail OAuth Integration
# You don't need to put the client secret here directly. 
# Instead, download the 'credentials.json' from Google Cloud Console
# and place it in the same folder as this file.

# 3. Observability
# Set to DEBUG if you want to see verbose logs, or INFO for standard
LOG_LEVEL="INFO"
